# ---------------------------------------------
# Deployment Environment Variables Example
# ---------------------------------------------
# Note: In cloud platforms (Render/Railway/Vercel)
# you will configure these in the platform dashboard.

# Node Server Port (Usually automatically injected)
PORT=3000

# Database Connection
# Cloud providers often inject DATABASE_URL natively.
# Otherwise, MONGO_URI works identically.
DATABASE_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/r360?retryWrites=true&w=majority

# Security
# Required: Must be at least 32 characters long
JWT_SECRET=replace_this_with_a_secure_random_string_in_production

# CORS / Security
# URL of your deployed frontend to allow safe cross-origin traffic
FRONTEND_URL=https://your-frontend.vercel.app

# Optional Configurations
NODE_ENV=production
LOG_LEVEL=info
GOOGLE_CLIENT_ID=

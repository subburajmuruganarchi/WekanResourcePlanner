# ---------------------------------------------
# Deployment Environment Variables Example
# ---------------------------------------------
# Note: In cloud platforms (Render/Railway/Vercel)
# you will configure these in the platform dashboard.

# Node Server Port (Usually automatically injected)
PORT=3000

# Database Connection (REQUIRED — use MONGO_URI or DATABASE_URL)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/r360?retryWrites=true&w=majority
# DATABASE_URL=mongodb+srv://...  # alternative to MONGO_URI

# Security (REQUIRED — minimum 32 characters)
JWT_SECRET=replace_this_with_a_secure_random_string_at_least_32_chars

# CORS (REQUIRED in all environments)
FRONTEND_URL=https://your-frontend.vercel.app

# Optional Configurations
NODE_ENV=production
LOG_LEVEL=info
GOOGLE_CLIENT_ID=

# Google Sheet sync (Apps Script webhook — push-based)
# GOOGLE_SHEET_SYNC_SECRET=replace_with_long_random_secret_min_16_chars
# GOOGLE_SHEET_ID=your-spreadsheet-id
# GOOGLE_APPS_SCRIPT_WEB_APP_URL=https://script.google.com/a/macros/wekancode.com/s/AKfycbyB6NJiR7nfixnupl--7Al8qeIYGOQSGUHivyXUCE8-8LGYkYgeatI2j7_pesbFoXeb0A/exec

# Phase 1 — Weekly resource planning (disabled by default)
FEATURE_WEEKLY_ALLOCATIONS_ENABLED=false
FEATURE_WEEKLY_ALLOCATIONS_LEGACY_READ=true
FEATURE_WEEKLY_ALLOCATIONS_VALIDATE_CAPACITY=true
WEEKLY_CAPACITY_HOURS=40

# Planned vs actual utilization reconciliation
FEATURE_UTILIZATION_API_ENABLED=true
FEATURE_WEEKLY_ACTUALS_SYNC_ENABLED=true
FEATURE_WEEKLY_UTILIZATION_SNAPSHOTS=true

# WeKan planner seed (backend/data/planner/ split sheets by default)
# PLANNER_SHEETS_DIR=./data/planner
# PLANNER_RESOURCE_XLSX=./data/planner/Resource.xlsx
# PLANNER_PROJECT_XLSX=./data/planner/Project.xlsx
# PLANNER_ALLOCATION_XLSX=./data/planner/Project_Allocation.xlsx
# PLANNER_XLSX_PATH=C:/path/to/full-workbook.xlsx
